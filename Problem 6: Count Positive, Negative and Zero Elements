arr = [5, -3, 0, 10, -7, 0, 2] 

positive_count = 0
negative_count = 0 
zero_count = 0 

for x in arr:
    if x >  0:
        positive_count = positive_count + 1

    elif x < 0:
        negative_count = negative_count + 1

    else:
        zero_count = zero_count + 1

print("positive count", positive_count)
print("negative count", negative_count)
print("zero count", zero_count)

